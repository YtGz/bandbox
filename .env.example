# ── Domain ──────────────────────────────────────────────────
# The public domain BandBox is served from.
DOMAIN=bandbox.example.com

# ── Convex ──────────────────────────────────────────────────
CONVEX_URL=https://your-deployment.convex.cloud
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Authentication (Pi → SvelteKit) ────────────────────────
PI_API_KEY=change-me-to-a-random-secret

# ── Authentication (Python Worker → Convex HTTP actions) ───
WORKER_API_KEY=change-me-to-a-different-secret

# ── Authentication (oauth2-proxy → OIDC provider) ─────────
# Create an OIDC client in your provider and paste the credentials here.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# OIDC issuer URL. Defaults to the bundled Pocket-ID instance.
# Set this when using an external OIDC provider (e.g. your own Pocket-ID,
# Keycloak, Authentik, etc.).
# OIDC_ISSUER_URL=https://id.example.com/oidc

# Host port for oauth2-proxy (BYO mode). Your reverse proxy points here.
# Default: 4180. Change to avoid conflicts with other services.
# OAUTH2_PROXY_PORT=4180

# Random 32-byte base64 string for cookie encryption.
# Generate with: openssl rand -base64 32
COOKIE_SECRET=

# ── LLM (for song grouping) ────────────────────────────────
# Default: Anthropic API with claude-opus-4-6
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-opus-4-6
