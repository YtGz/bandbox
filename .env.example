# Convex
CONVEX_URL=https://your-deployment.convex.cloud
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Pi upload authentication
PI_API_KEY=change-me-to-a-random-secret

# Worker authentication (for Convex HTTP actions)
WORKER_API_KEY=change-me-to-a-different-secret

# Audio file storage (default: /data/audio)
# AUDIO_DATA_PATH=/data/audio

# Pocket-ID OIDC
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=
POCKET_ID_ISSUER_URL=https://auth.datawarp.dev/pocket-id

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# LLM (for song grouping)
LLM_API_KEY=
LLM_BASE_URL=
