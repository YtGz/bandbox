{$DOMAIN} {
    # Pocket-ID — OIDC provider (standalone profile only)
    handle /pocket-id/* {
        reverse_proxy pocket-id:8080
    }

    # Everything else — oauth2-proxy handles auth and proxies to SvelteKit.
    # Unauthenticated users are redirected to the OIDC login.
    # /api/upload is skipped by oauth2-proxy (Pi uses API key auth).
    handle {
        reverse_proxy oauth2-proxy:4180
    }
}
